'use client'

import React, { Suspense, useEffect, useRef, useState } from 'react'
import { Canvas, useFrame, useThree } from '@react-three/fiber'
import { Environment, ContactShadows, Center } from '@react-three/drei'
import { AjModel, ActionName } from './AjModel'
import gsap from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'
import * as THREE from 'three'

// Register GSAP ScrollTrigger
gsap.registerPlugin(ScrollTrigger)

function ScrollytellingModel({ animation }: { animation: ActionName }) {
  const { camera, mouse } = useThree()
  const groupRef = useRef<THREE.Group>(null)
  const modelRef = useRef<THREE.Group>(null)
  
  useFrame(() => {
    if (modelRef.current) {
      const head = modelRef.current.getObjectByName('mixamorigHead')
      const targetRotationY = mouse.x * 0.3
      const targetRotationX = -mouse.y * 0.15
      
      if (head) {
        head.rotation.y = THREE.MathUtils.lerp(head.rotation.y, targetRotationY, 0.1)
        head.rotation.x = THREE.MathUtils.lerp(head.rotation.x, targetRotationX, 0.1)
      } else {
        modelRef.current.rotation.y = THREE.MathUtils.lerp(modelRef.current.rotation.y, targetRotationY, 0.05)
        modelRef.current.rotation.x = THREE.MathUtils.lerp(modelRef.current.rotation.x, targetRotationX, 0.05)
      }
    }
  })

  useEffect(() => {
    if (!groupRef.current) return

    const ctx = gsap.context(() => {
      // Hero Reset
      gsap.to(camera.position, {
        x: 0, y: 0, z: 5,
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 1,
        },
      })

      // About Transition
      gsap.to(groupRef.current!.position, {
        x: 1.5,
        y: -1,
        scrollTrigger: {
          trigger: '#about',
          start: 'top bottom',
          end: 'top center',
          scrub: 1,
        },
      })
      
      gsap.to(groupRef.current!.scale, {
        x: 1.2, y: 1.2, z: 1.2,
        scrollTrigger: {
          trigger: '#about',
          start: 'top bottom',
          end: 'top center',
          scrub: 1,
        },
      })
    })

    return () => ctx.revert()
  }, [camera])

  return (
    <group ref={groupRef} position={[0, -1.0, 0]} rotation={[0, 0, 0]}>
      <group ref={modelRef}>
        <Center>
          <AjModel scale={0.015} animation={animation} />
        </Center>
      </group>
    </group>
  )
}

function SceneContent({ animation }: { animation: ActionName }) {
  return (
    <Suspense fallback={null}>
      <ScrollytellingModel animation={animation} />

      {/* Balanced Rim Lighting */}
      <pointLight position={[0, 2, -2]} color="#a78bfa" intensity={10} />

      {/* Subtle front fill to highlight details without washing out */}
      <directionalLight position={[0, 5, 5]} intensity={1.2} color="#ffffff" />

      {/* Environment for realistic reflections, kept subtle */}
      <Environment preset="city" environmentIntensity={0.8} />

      <ContactShadows 
        opacity={0.6} 
        scale={15} 
        blur={2.5} 
        far={5}
        position={[0, -1.1, 0]}
      />
    </Suspense>
  )
}

export default function PortfolioPage() {
  const [currentAnim, setCurrentAnim] = useState<ActionName>('BreathingIdle')
  const heroTextRef = useRef<HTMLDivElement>(null)
  const bgNameRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    // 1. Entrance Animation for foreground text
    gsap.from(heroTextRef.current, {
      y: 50,
      opacity: 0,
      duration: 1.5,
      ease: 'power4.out',
      delay: 0.5
    })

    // 2. Smooth Fade-out for Background Name on Scroll
    gsap.to(bgNameRef.current, {
      opacity: 0,
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom center',
        scrub: true,
      }
    })

    const triggers = [
      { id: '#hero', anim: 'BreathingIdle' },
      { id: '#about', anim: 'WavingGesture' },
      { id: '#projects', anim: 'ThumbsUp' }
    ]

    triggers.forEach(t => {
      ScrollTrigger.create({
        trigger: t.id,
        start: 'top center',
        onEnter: () => setCurrentAnim(t.anim as ActionName),
        onEnterBack: () => setCurrentAnim(t.anim as ActionName),
      })
    })
  }, [])

  return (
    <div className="relative bg-black text-white selection:bg-purple-500 font-sans overflow-x-hidden">
      
      {/* Film Grain */}
      <div className="fixed inset-0 z-50 pointer-events-none opacity-[0.03] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] brightness-100 contrast-150"></div>

      {/* 1. PREMIUM DARK BACKGROUND & GLOW */}
      <div className="fixed inset-0 z-0 bg-black pointer-events-none overflow-hidden">
        {/* The 'Glow' div at bottom-center - RESTORED */}
        <div className="absolute bottom-[-10vh] left-1/2 -translate-x-1/2 w-[120vw] h-[60vh] bg-[#4c1d95] rounded-full blur-[150px] opacity-50"></div>
        
        {/* MAIN NAME: Repositioned higher and improved visibility */}
        <div ref={bgNameRef} className="absolute inset-0 flex flex-col items-center justify-center pointer-events-none select-none z-10">
           <div className="flex flex-col items-center justify-center opacity-40 animate-text-breath mt-[-15vh]">
             <h1 className="text-[15vw] font-black tracking-[-0.02em] leading-none uppercase text-transparent font-impasse"
                 style={{ WebkitTextStroke: '1.5px rgba(255,255,255,0.3)' }}>
              Arnav
            </h1>
            <h1 className="text-[15vw] font-black tracking-[-0.02em] leading-none uppercase text-transparent font-impasse -mt-[4vw]"
                 style={{ WebkitTextStroke: '1.5px rgba(255,255,255,0.3)' }}>
              Raj
            </h1>
          </div>
        </div>
      </div>

      {/* MIDDLE LAYER: 3D MASCOT (z-10) */}
      <div className="fixed inset-0 z-10 w-full h-full pointer-events-none flex items-center justify-center overflow-visible">
        <Canvas 
          shadows 
          gl={{ alpha: true, antialias: true }}
          camera={{ position: [0, 0, 5], fov: 40 }}
          onCreated={({ gl }) => {
            gl.toneMapping = THREE.ACESFilmicToneMapping
            gl.setClearColor(0x000000, 0)
          }}
        >
          {/* Restored lighting for a solid look */}
          <ambientLight intensity={1.0} />
          <spotLight position={[10, 15, 10]} angle={0.3} penumbra={1} intensity={2} castShadow />
          <SceneContent animation={currentAnim} />
        </Canvas>
      </div>

      {/* FOREGROUND LAYER: UI CONTENT (z-20) */}
      <main className="relative z-30 pointer-events-none">
        
        {/* HERO SECTION */}
        <section id="hero" className="relative flex flex-col items-center justify-center min-h-screen">
          <div ref={heroTextRef} className="absolute bottom-32 text-center w-full">
            {/* LOCATION: Based in India */}
            <div className="mb-4 font-mono text-[10px] tracking-[0.4em] text-violet-400 uppercase opacity-80">
              Based in India
            </div>
            
            {/* ROLE TITLE: Improved visibility with stronger gradient */}
            <h2 className="text-xl md:text-2xl font-black tracking-[0.6em] uppercase bg-clip-text text-transparent bg-gradient-to-r from-white via-violet-400 to-fuchsia-500 mb-4 drop-shadow-[0_0_20px_rgba(167,139,250,0.4)] font-impasse-bold">
              Full Stack Developer
            </h2>
            
            {/* SUBTEXT: Removed italics, kept clean and modern */}
            <p className="text-slate-400 text-[10px] md:text-xs font-mono tracking-[0.3em] uppercase opacity-90">
              Crafting immersive digital experiences.
            </p>
          </div>

          <div className="absolute bottom-4 flex flex-col items-center gap-3 opacity-20">
             <span className="text-[8px] font-mono tracking-[0.5em] uppercase">Scroll to Discover</span>
            <div className="w-[1px] h-12 bg-gradient-to-b from-white to-transparent"></div>
          </div>
        </section>

        {/* Other sections need to remain interactive, so we override pointer-events */}
        <section id="about" className="min-h-[120vh] p-10 md:p-32 flex items-center pointer-events-auto">
          <div className="max-w-xl p-12 rounded-[3.5rem] bg-white/[0.02] backdrop-blur-3xl border border-white/5 shadow-2xl relative z-30">
            <h2 className="text-[10px] font-mono font-bold tracking-[0.5em] uppercase text-violet-400 mb-8 font-impasse">01 / STORY</h2>
            <h3 className="text-6xl font-black mb-8 tracking-tighter leading-[0.9] font-impasse-bold">Architecting <br/> <span className="text-gray-500">Innovation.</span></h3>
            <p className="text-xl text-gray-400 leading-relaxed font-light">
              I'm Arnav Raj, a developer focused on the intersection of scalable code and high-end aesthetics. 
              My work transforms complex problems into seamless user journeys.
            </p>
          </div>
        </section>

        <section id="projects" className="min-h-[120vh] p-10 md:p-32 flex items-center justify-start pointer-events-auto">
          <div className="max-w-xl p-12 rounded-[3.5rem] bg-white/[0.02] backdrop-blur-3xl border border-white/5 shadow-2xl relative z-30">
             <h2 className="text-[10px] font-mono font-bold tracking-[0.5em] uppercase text-violet-400 mb-8 font-impasse">02 / WORK</h2>
             <h3 className="text-6xl font-black mb-10 tracking-tighter leading-[0.9] font-impasse-bold">Digital <br/> <span className="text-gray-500">Mastery.</span></h3>
             <div className="space-y-6 text-gray-400">
                {['Nexus 3D Store', 'Lumina AI Mobile', 'Vortex Dashboard'].map((project) => (
                  <div key={project} className="flex items-center justify-between border-b border-white/5 pb-4 group cursor-pointer hover:text-white transition-colors">
                    <span className="text-2xl font-bold tracking-tighter italic uppercase">{project}</span>
                    <span className="text-[10px] font-mono text-violet-400 opacity-0 group-hover:opacity-100 transition-opacity tracking-widest uppercase">Explore</span>
                  </div>
                ))}
             </div>
          </div>
        </section>

        <section id="contact" className="min-h-screen flex items-center justify-center pointer-events-auto">
           <div className="text-center px-10 relative z-30">
             <h2 className="text-[15vw] font-black opacity-[0.03] tracking-tighter uppercase pointer-events-none font-impasse"
                 style={{ WebkitTextStroke: '1px rgba(255,255,255,0.2)', color: 'transparent' }}>CONNECT</h2>
             <a href="mailto:hello@arnavraj.com" className="text-4xl md:text-8xl font-black tracking-tighter hover:text-violet-400 transition-all duration-700 uppercase font-impasse-bold">hello@arnavraj.com</a>
           </div>
        </section>

      </main>

      <style jsx global>{`
        @font-face {
          font-family: 'Impasse';
          src: url('/impasse/Impasse.otf') format('opentype');
          font-weight: normal;
          font-style: normal;
        }
        @font-face {
          font-family: 'ImpasseBold';
          src: url('/impasse/ImpasseBold.otf') format('opentype');
          font-weight: bold;
          font-style: normal;
        }
        
        body {
          background: #000000;
          font-family: 'Geist', sans-serif;
          cursor: crosshair;
          -webkit-font-smoothing: antialiased;
        }

        .font-impasse { font-family: 'Impasse', sans-serif; }
        .font-impasse-bold { font-family: 'ImpasseBold', sans-serif; }
        .font-mono { font-family: 'Geist Mono', monospace; }

        @keyframes pulse-slow {
          0%, 100% { opacity: 0.4; transform: scale(1); }
          50% { opacity: 0.6; transform: scale(1.05); }
        }
        
        @keyframes text-breath {
          0%, 100% { transform: scale(1); }
          50% { transform: scale(1.02); }
        }

        .animate-pulse-slow {
          animation: pulse-slow 8s infinite ease-in-out;
        }

        .animate-text-breath {
          animation: text-breath 10s infinite ease-in-out;
        }

        html, body {
          height: 100%;
          overscroll-behavior: none;
        }
      `}</style>
    </div>
  )
}
